# Telegram Bot 설정
# BotFather를 통해 발급받은 봇 토큰을 입력하세요.
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# 접근 허용 유저 리스트 (콤마로 구분된 숫자 표기)
# 예: "12345678,87654321"
ALLOWED_USER_IDS="your_telegram_user_id_here"

# LM Studio 서버 설정
# LM Studio Local Inference Server 의 기본 주소 (보통 1234 포트)
LM_STUDIO_BASE_URL="http://127.0.0.1:1234/v1"

# 대부분의 경우 기본값 유지
LM_STUDIO_API_KEY="lm-studio"
